# ============================================================================
# SUPABASE
# ============================================================================
# Dal dashboard Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service Role Key: SOLO server-side (per cron scan). MAI esporre al client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ============================================================================
# CRON / SCANNER
# ============================================================================
# Segreto per proteggere l'endpoint /api/cron/scan.
# Vercel Cron invia l'header `Authorization: Bearer $CRON_SECRET`
CRON_SECRET=genera-una-stringa-random-lunga

# ============================================================================
# TELEGRAM (opzionale — notifiche segnali)
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
